rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && request.auth.uid in [
          "DEINE_ADMIN_UID_HIER_EINFUEGEN"
        ];
    }

    match /settings/{settingId} {
      allow read: if true;
      // Helfer dürfen nur den Aktualisierungs-Zeitstempel auslösen.
      allow create, update: if isAdmin() || (
        request.resource.data.keys().hasOnly(["vereinName", "updatedAt"])
        && request.resource.data.vereinName == "Union Gampern"
      );
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();

      match /schichten/{schichtId} {
        allow read: if true;
        allow create, delete: if isAdmin();
        allow update: if isAdmin() || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(["belegt", "updatedAt"])
          && request.resource.data.belegt == resource.data.belegt + 1
          && request.resource.data.belegt <= resource.data.benoetigt
        );
      }

      match /anmeldungen/{anmeldungId} {
        allow read: if true;
        allow create: if isAdmin() || (
          request.resource.data.keys().hasOnly(["schichtId", "name", "createdAt"])
          && request.resource.data.schichtId is string
          && request.resource.data.name is string
          && request.resource.data.name.size() >= 2
          && request.resource.data.name.size() <= 80
          && request.resource.data.createdAt == request.time
        );
        allow update, delete: if isAdmin();
      }
    }
  }
}
